classDiagram
    class Owner {
        +str name
        +list~Pet~ pets
        +list~str~ preferences
        +int daily_time_budget_minutes
        +add_pet(pet: Pet) None
        +add_preference(preference: str) None
        +get_all_tasks() list~Task~
        +get_tasks(pet_name: str | None = None, completed: bool | None = None) list~Task~
        +summary() str
    }

    class Pet {
        +str name
        +str species
        +int age_years
        +list~Task~ care_tasks
        +list~str~ care_notes
        +add_task(task: Task) None
        +profile_summary() str
        +add_care_note(note: str) None
        +task_count() int
        +get_tasks(completed: bool | None = None) list~Task~
    }

    class Task {
        +str description
        +int duration_minutes
        +str frequency
        +str priority
        +str preferred_time
        +str due_date
        +Pet pet
        +bool completed
        +str completion_timestamp
        +str skipped_reason
        +mark_complete() None
        +clone_for_next_occurrence() Task
        +priority_score(owner: Owner | None = None) int
        +can_fit(available_minutes: int) bool
        +schedule_label() str
    }

    class Scheduler {
        +Owner owner
        +collect_tasks() list~Task~
        +sort_by_time() list~Task~
        +filter_tasks(pet_name: str | None = None, completed: bool | None = None) list~Task~
        +mark_task_complete(task: Task) Task | None
        +sort_tasks() list~Task~
        +expand_recurring_tasks() list~Task~
        +detect_conflicts() list~str~
        +build_plan() list~Task~
        +explain_plan() str
    }

    Owner "1" o-- "*" Pet : owns
    Pet "1" o-- "*" Task : has
    Task "0..1" --> "1" Pet : assigned_to
    Scheduler --> Owner : plans_for