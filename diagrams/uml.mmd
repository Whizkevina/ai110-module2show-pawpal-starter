classDiagram
    class Owner {
        +str name
        +list~Pet~ pets
        +list~str~ preferences
        +int daily_time_budget_minutes
        +add_pet(pet: Pet) None
        +add_preference(preference: str) None
        +summary() str
    }

    class Pet {
        +str name
        +str species
        +int age_years
        +list~Task~ care_tasks
        +list~str~ care_notes
        +profile_summary() str
        +add_task(task: Task) None
        +add_care_note(note: str) None
    }

    class Task {
        +str description
        +int duration_minutes
        +str frequency
        +str priority
        +str preferred_time
        +Pet pet
        +bool completed
        +str completion_timestamp
        +str skipped_reason
        +mark_complete() None
        +priority_score(owner: Owner) int
        +can_fit(available_minutes: int) bool
    }

    class Scheduler {
        +Owner owner
        +collect_tasks() list~Task~
        +sort_tasks() list~Task~
        +build_plan() list~Task~
        +explain_plan() str
    }

    Owner "1" o-- "*" Pet : owns
    Pet "1" o-- "*" Task : needs
    Scheduler --> Owner : plans_for
